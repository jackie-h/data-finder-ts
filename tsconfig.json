{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@datafinder": ["./src/datafinder/index"],
      "@datafinder/*": ["./src/datafinder/*"],
      "@model/*": ["./src/model/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*", "example/generated/**/*"]
}
